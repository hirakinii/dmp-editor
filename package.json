{
  "name": "dmp-editor",
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "test:lint": "eslint '{src,test}/**/*.{ts,tsx}' --fix",
    "test:typecheck": "tsc --noEmit",
    "test:vitest": "vitest run --root .",
    "ci": "npm run test:lint && npm run test:typecheck && npm run test:vitest && npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
